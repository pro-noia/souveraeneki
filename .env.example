# Diese Datei dokumentiert alle erwarteten Umgebungsvariablen.
# Kopiere sie zu .env.local für lokale Entwicklung — .env* ist gitignored.
#
# Für Production: Werte in Vercel hinterlegen über
#   Vercel Dashboard → Projekt souveraeneki → Settings → Environment Variables
# Scope für jede Variable: Production + Preview (optional Development).

# --- Brevo (Whitepaper-Lead-Magnet) ---------------------------------------
# API-Key aus dem Brevo-Account:
#   https://app.brevo.com → SMTP & API → API Keys → Generate a new API key
# Format: xkeysib-…
BREVO_API_KEY=xkeysib-…

# Listen-ID der „Whitepaper"-Liste in Brevo:
#   https://app.brevo.com → Contacts → Lists → Liste anlegen → ID notieren
# Ganzzahl, z. B. 3
BREVO_WHITEPAPER_LIST_ID=

# --- Replicate (Glossar-Hero-Bilder, nur lokal benötigt) ------------------
# API-Token aus dem Replicate-Account:
#   https://replicate.com/account/api-tokens
# Format: r8_…
REPLICATE_API_TOKEN=
